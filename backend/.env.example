# NHCservice Backend - Environment Configuration Template

# Server
PORT=5001
NODE_ENV=production
ALLOWED_ORIGINS=https://nhcservice.com,https://your-frontend.vercel.app

# Database
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/nhcservice?retryWrites=true&w=majority
REDIS_URL=redis://<user>:<password>@redis-cloud-endpoint:6379

# Auth
JWT_SECRET=your_super_secret_production_key_change_me
JWT_EXPIRY=1d

# AI Providers
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_WEBHOOK_URL=https://your-backend-url.railway.app


# Automation / Webhooks
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/healthcare
WHATSAPP_CLOUD_API_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_id
